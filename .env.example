# Copy to .env and adjust before deploy.

# Public URL used by browser/Next.js. For VPS without reverse proxy, use the VPS IP/domain + ports.
NEXT_PUBLIC_APP_URL=http://43.156.118.114:3000
NEXT_PUBLIC_FASTAPI_BASE_URL=http://43.156.118.114:8000

# Docker published ports. Change if these ports are already used.
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Backend security
APP_ENV=production
APP_DEBUG=0
AUTH_COOKIE_SECURE=0
# Set AUTH_COOKIE_SECURE=1 only when served over HTTPS.

# Generate with: openssl rand -hex 32
AUTH_SECRET=change-this-to-a-long-random-secret

# Next.js Better Auth / local SQLite auth database
BETTER_AUTH_URL=http://43.156.118.114:3000
BETTER_AUTH_SECRET=change-this-too-with-openssl-rand-hex-32
DATABASE_URL=file:/app/data/sqlite.db

# One-time first admin bootstrap token. Generate with: openssl rand -hex 24
ADMIN_SETUP_TOKEN=change-this-one-time-setup-token

# Temporary plain password format is supported by backend, but hashes are recommended for production.
# Example temporary only:
AUTH_USERS=admin:change-this-password
AUTH_ADMINS=admin
AUTH_FINANCE=

# Optional Accurate OAuth / API wrapper settings
NEXT_PUBLIC_ACCURATE_CLIENT_ID=
ACCURATE_CLIENT_ID=
ACCURATE_CLIENT_SECRET=
NEXT_PUBLIC_ACCURATE_REDIRECT_URI=http://43.156.118.114:3000/api/auth/callback

# Optional email settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional AI/OCR integrations used by backend features
SUMOPOD_API_KEY=
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1
SUMOPOD_MODEL=gemini/gemini-2.5-flash
OPENAI_API_KEY=
BYTEPLUS_ARK_API_KEY=
SEEDANCE_PROXY_TOKEN=
