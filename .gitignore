# Tujuan: Aturan ignore root agar source AccAPI terpisah dari dependency, secret, runtime data, dan file kerja lokal.
# Caller: Git, Codex deployment workflow, dan developer lokal saat staging commit.
# Dependensi: Struktur repo Next.js/FastAPI, output Python, SQLite lokal, dan artefak dokumen kerja.
# Main Functions: Mengecualikan build output, environment secret, database/cache, logs, scratch, dan workbook/PDF lokal.
# Side Effects: File yang match pola ini tidak otomatis masuk staging Git.

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local databases and runtime state
*.sqlite
*.sqlite3
*.db
sqlite.db
database.sqlite
python_backend/database.sqlite
python_backend/data/*.json
python_backend/data/*.jsonl
python_backend/data/*.bak
!python_backend/data/.gitkeep

# generated outputs, uploads, and runtime logs
python_backend/output/
python_backend/output/payments/
python_backend/output/payments/proofs/
runtime_logs/
scratch/
*.log

# local business documents and spreadsheet/PDF work files
*.xlsx
*.xls
*.csv
*.pdf
~$*

# local debug artifacts and editor workspaces
runtime/
.kilo/

# local skill/tooling repos & scratch docs (bukan kode app)
awesome-codex-skills/
docs/superpowers/

# crash dumps / junk
*.stackdump

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# arsip, installer, dump DB & sidecar SQLite — hardblock data raksasa (jangan masuk git)
*.rar
*.zip
*.7z
*.exe
*.apl
*.bak
*.bak*
*.gz
*.db-wal
*.db-shm
*.db-journal

# dashboard-generator: source only, artefak build/output jangan masuk git
dashboard-generator/build/
dashboard-generator/dist/
dashboard-generator/__pycache__/
dashboard-generator/output_*.html
dashboard-generator/samples/
dashboard-generator/reference/

# python_backend runtime debug artifacts
python_backend/data/debug_ai.txt
python_backend/data/e2e_live_output/

# materi referensi bisnis (PDF surat program asli) & poster visi — bukan source code
reference_surat_program/
poster/

# plugin lokal Claude (bukan bagian app)
ponytail/
